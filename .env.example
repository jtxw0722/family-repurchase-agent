FAMILY_AGENT_DB=./data/family-repurchase.sqlite
NORMALIZATION_LLM_ENABLED=false
NORMALIZATION_LLM_PROVIDER=openai-compatible
NORMALIZATION_LLM_MODEL=gpt-4.1-mini
NORMALIZATION_LLM_API_KEY=
NORMALIZATION_LLM_BASE_URL=https://api.openai.com/v1
NORMALIZATION_LLM_PROMPT_VERSION=normalization-v1
# 可按 provider 性能调整为 60 或 90。
NORMALIZATION_LLM_TIMEOUT_SECONDS=30
# 可按 provider 性能调整为 3 或 10；慢速 provider 建议先用 3。
NORMALIZATION_LLM_BATCH_SIZE=10
NORMALIZATION_LLM_EXCLUDE_CONFIDENCE_THRESHOLD=0.9
NORMALIZATION_LLM_NORMALIZE_CONFIDENCE_THRESHOLD=0.9
NORMALIZATION_LLM_REVIEW_CONFIDENCE_THRESHOLD=0.85
NORMALIZATION_FALLBACK_REVIEW_MODE=llm_suggestion
