{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "商品归一化 LLM 输出格式说明（normalization-v1）。仅作文档化和版本管理，不用于运行时校验。",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "action", "productType", "unitFamily", "confidence", "reviewRequired"],
    "properties": {
      "index": {
        "type": "integer",
        "description": "1-based 对应输入 items 的 index"
      },
      "action": {
        "type": "string",
        "enum": ["NORMALIZE", "EXCLUDE", "NEW_CATEGORY", "REVIEW"],
        "description": "建议动作"
      },
      "productType": {
        "type": "string",
        "enum": ["REPURCHASE_CONSUMABLE", "NON_REPURCHASE", "DURABLE", "COUPON_OR_DEPOSIT", "UNKNOWN"],
        "description": "商品类型"
      },
      "normalizedName": {
        "type": ["string", "null"],
        "description": "归一化后的商品名称"
      },
      "targetUnit": {
        "type": ["string", "null"],
        "description": "目标计量单位，只能是 g/ml/片/罐/包 等单位，不得是规格值"
      },
      "unitFamily": {
        "type": "string",
        "enum": ["WEIGHT", "VOLUME", "COUNT", "PIECE", "UNKNOWN"],
        "description": "单位族"
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1,
        "description": "置信度"
      },
      "reviewRequired": {
        "type": "boolean",
        "description": "是否需要人工复核"
      },
      "reasonCode": {
        "type": ["string", "null"],
        "description": "原因码，只能从输入 context.reasonCodes 选择"
      },
      "shortReason": {
        "type": ["string", "null"],
        "description": "简短原因，最多 16 个中文字符"
      }
    }
  }
}
