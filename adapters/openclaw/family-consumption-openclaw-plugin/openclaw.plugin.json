{
  "id": "family-consumption-agent",
  "name": "Family Consumption Agent",
  "description": "Expose local household consumption analysis tools to OpenClaw.",
  "version": "0.3.0",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "family_consumption_import_file",
      "family_consumption_compare_price",
      "family_consumption_generate_report"
    ]
  },
  "toolMetadata": {
    "family_consumption_import_file": {
      "optional": true
    },
    "family_consumption_generate_report": {
      "optional": true
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiBaseUrl": {
        "type": "string",
        "description": "Spring Boot REST Tool API base URL.",
        "default": "http://localhost:8080"
      },
      "projectRoot": {
        "type": "string",
        "description": "family-consumption-agent workspace root used to resolve relative import paths.",
        "default": "."
      },
      "importAllowedDirs": {
        "type": "array",
        "description": "Directories allowed for import_file.",
        "items": {
          "type": "string"
        },
        "default": [
          "examples",
          "data/imports",
          "imports"
        ]
      }
    }
  }
}
